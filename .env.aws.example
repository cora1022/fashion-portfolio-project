# Copy to .env only on the deployment host. Do not commit .env.
SITE_ADDRESS=https://your-domain.example
VITE_API_BASE_URL=
QDRANT_COLLECTION_NAME=fashion_catalog_v1
FASHIONCLIP_MODEL_NAME=patrickjohncyh/fashion-clip
FASHIONCLIP_MODEL_REVISION=main
FASHIONCLIP_VECTOR_SIZE=512
MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_PIXELS=16000000
INFERENCE_MAX_CONCURRENCY=1
INFERENCE_QUEUE_TIMEOUT_SECONDS=5
SEARCH_TIMEOUT_SECONDS=45
BACKEND_CPUS=2
BACKEND_MEMORY=4g
QDRANT_CPUS=1
QDRANT_MEMORY=1g
CORS_ORIGINS=https://your-domain.example
MYSQL_USER=stylefinder
MYSQL_PASSWORD=replace-with-a-strong-secret
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-secret
JWT_ISSUER=style-finder-member-service
JWT_AUDIENCE=style-finder-api
MEMBER_CORS_ORIGINS=https://your-domain.example
