SITE_ADDRESS=http://localhost
VITE_API_BASE_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=fashion_catalog_v1
FASHIONCLIP_MODEL_NAME=patrickjohncyh/fashion-clip
FASHIONCLIP_MODEL_REVISION=main
FASHIONCLIP_VECTOR_SIZE=512
MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_PIXELS=16000000
INFERENCE_MAX_CONCURRENCY=1
INFERENCE_QUEUE_TIMEOUT_SECONDS=5
SEARCH_TIMEOUT_SECONDS=45
CATALOG_MANIFEST_PATH=catalog/manifest.json
CATALOG_IMAGES_DIR=catalog/images
OPENCV_CROP_ENABLED=true
YOLO_CLOTHING_MODEL_PATH=backend/models/yolov8n-clothing-detection-best.pt
YOLO_CONFIDENCE=0.25
CORS_ORIGINS=http://localhost,http://localhost:5173
MYSQL_USER=stylefinder
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password
JWT_SECRET=change-this-local-development-secret-to-at-least-32-bytes
MEMBER_CORS_ORIGINS=http://localhost,http://localhost:5173
